diff --git a/app/src/main/java/com/sherif/ledger/core/designsystem/atmosphere/LedgerAtmosphereGlow.kt b/app/src/main/java/com/sherif/ledger/core/designsystem/atmosphere/LedgerAtmosphereGlow.kt
